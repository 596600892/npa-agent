# NPA Agent local runtime example.
# Copy to .env only if your local launcher reads it; do not commit real secrets.

# Local web service. Use another port if 8765 is occupied.
HOST=127.0.0.1
PORT=8765
PUBLIC_URL=http://127.0.0.1:8765

# Data remains local by default. Runtime files under data/ are ignored by git.
NPA_DATA_DIR=./data

# Model configuration is normally saved through the UI.
# Keep keys local. Never commit real API keys.
NPA_MODEL_PROVIDER=deepseek
NPA_MODEL_BASE_URL=https://api.deepseek.com/v1
NPA_MODEL_NAME=deepseek-chat
NPA_MODEL_API_KEY=
NPA_MODEL_SAFETY_MODE=redacted_cloud

# Voice configuration is normally saved through the UI.
NPA_VOICE_PROVIDER=builtin_browser
NPA_VOICE_API_KEY=
